# ─────────────────────────────────────────────────────────────────────────────
# ClearPaws — Production Environment Variables
# Copy this file, fill in real values, and add each key to Vercel.
# NEVER commit a file with real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ────────────────────────────────────────────────────────────────
# Production API key from console.anthropic.com
ANTHROPIC_API_KEY=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — Settings > API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Live secret key from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Live publishable key — safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — from Stripe Dashboard > Webhooks > your endpoint
# Must match the endpoint: https://clearpaws.com.au/api/webhook/stripe
STRIPE_WEBHOOK_SECRET=

# Price ID for the $49 AUD one-time document pack
# Create in Stripe Dashboard > Products
STRIPE_PRICE_ID=

# Price ID for the $9.90 AUD/month subscription
STRIPE_SUBSCRIPTION_PRICE_ID=

# Price ID for the $299 AUD/month B2B agency white-label portal
B2B_STRIPE_PRICE_ID=

# ── Resend (email) ────────────────────────────────────────────────────────────
# API key from resend.com — used for deadline reminders and DAFF alerts
RESEND_API_KEY=

# ── App config ────────────────────────────────────────────────────────────────
# Production base domain (no protocol, no trailing slash)
NEXT_PUBLIC_BASE_DOMAIN=clearpaws.com.au

# ── Admin ────────────────────────────────────────────────────────────────────
# Email address that receives DAFF rule-change alerts and vet registration notifications
ADMIN_EMAIL=

# ── Cron security ────────────────────────────────────────────────────────────
# Random secret shared between Vercel Cron and the cron API routes.
# Generate with: openssl rand -hex 32
# Vercel adds this automatically as Authorization: Bearer <secret>
CRON_SECRET=
